# ==============================================================================
# ARQUIVO .env — VARIÁVEIS DE AMBIENTE PARA GMUD-006
# ==============================================================================
# ATENÇÃO: Este arquivo contém CREDENCIAIS SENSÍVEIS
# NUNCA commitar este arquivo no GitHub (protegido pelo .gitignore)
# ==============================================================================

# PostgreSQL - Senha do banco de dados
POSTGRES_PASSWORD=<SENHA_POSTGRES_AQUI>

# midPoint - Senha de conexão ao repositório PostgreSQL
MIDPOINT_REPOSITORY_DATABASE_PASSWORD=<SENHA_POSTGRES_AQUI>

# midPoint - Senha inicial do usuário administrator
# Esta variável será injetada no container e define a senha do primeiro acesso
MP_SET_midpoint_administrator_initialPassword=<SENHA_ADMINISTRATOR_AQUI>

# ==============================================================================
# EXEMPLO DE PREENCHIMENTO:
# ==============================================================================
# POSTGRES_PASSWORD=PMMRw7Rm6B4o7T
# MIDPOINT_REPOSITORY_DATABASE_PASSWORD=PMMRw7Rm6B4o7T
# MP_SET_midpoint_administrator_initialPassword=Fiqueok@2026!
# ==============================================================================

# INSTRUÇÕES:
# 1. Substitua os valores <SENHA_*_AQUI> pelas senhas reais
# 2. As senhas do PostgreSQL devem ser IGUAIS (POSTGRES_PASSWORD e MIDPOINT_REPOSITORY_DATABASE_PASSWORD)
# 3. A senha do administrator pode ser diferente (recomendado)
# 4. NÃO remova as aspas se a senha contiver caracteres especiais
# 5. Este arquivo é carregado automaticamente pelo script GMUD-006 v1.4.2
# ==============================================================================
